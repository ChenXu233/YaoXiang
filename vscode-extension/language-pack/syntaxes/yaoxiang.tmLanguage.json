{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YaoXiang",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#delimiters"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.yaoxiang",
          "match": "\\b(if|elif|else|match|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.yaoxiang",
          "match": "\\b(pub|use|spawn|ref|mut|unsafe)\\b"
        },
        {
          "name": "keyword.other.yaoxiang",
          "match": "\\bas\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.type.yaoxiang",
          "match": "\\bType\\b"
        },
        {
          "name": "constant.language.boolean.yaoxiang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.yaoxiang",
          "match": "\\bvoid\\b"
        },
        {
          "name": "support.type.yaoxiang",
          "match": "\\b(Maybe|Result)\\."
        },
        {
          "name": "support.function.yaoxiang",
          "match": "\\b(Some|Ok|Err)\\("
        }
      ]
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.yaoxiang",
      "patterns": [
        {
          "name": "constant.character.escape.yaoxiang",
          "match": "\\\\(\"|\\\\|[nrt\\\\])"
        },
        {
          "name": "string.interpolated.yaoxiang",
          "match": "\\$\\{[^}]+\\}"
        },
        {
          "name": "string.interpolated.yaoxiang",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.yaoxiang",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.octal.yaoxiang",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.binary.yaoxiang",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.float.yaoxiang",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.decimal.yaoxiang",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.yaoxiang",
          "match": "//.*$"
        },
        {
          "name": "comment.block.yaoxiang",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.yaoxiang",
          "match": "=>|->"
        },
        {
          "name": "keyword.operator.yaoxiang",
          "match": "(=|\\+|-|\\*|/|%|==|!=|<|>|>=|<=|&&|\\|\\||!|::)"
        }
      ]
    },
    "delimiters": {
      "patterns": [
        {
          "name": "punctuation.yaoxiang",
          "match": "[:,;\\[\\]{}\\(\\)]"
        }
      ]
    }
  },
  "scopeName": "source.yaoxiang"
}
