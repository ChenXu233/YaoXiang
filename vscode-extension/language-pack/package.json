{
  "name": "yaoxiang-language-pack",
  "displayName": "YaoXiang Language Pack",
  "description": "YaoXiang programming language support - syntax highlighting and language configuration",
  "version": "0.1.0",
  "publisher": "yaoxiang",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "yaoxiang",
        "aliases": [
          "YaoXiang",
          "yx"
        ],
        "extensions": [
          ".yx"
        ],
        "filenamePatterns": [
          "*.yx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "yaoxiang",
        "scopeName": "source.yaoxiang",
        "path": "./syntaxes/yaoxiang.tmLanguage.json"
      }
    ]
  }
}
