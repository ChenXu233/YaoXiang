{
  "name": "yaoxiang-language-server",
  "displayName": "YaoXiang Language Server",
  "description": "YaoXiang LSP server for VS Code - provides code completion, diagnostics, and more",
  "version": "0.1.0",
  "publisher": "yaoxiang",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:yaoxiang"
  ],
  "engines": {
    "vscode": "^1.70.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "postinstall": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "yaoxiang",
        "extensions": [
          ".yx"
        ]
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/vscode": "^1.70.0",
    "typescript": "^5.6.3"
  }
}
