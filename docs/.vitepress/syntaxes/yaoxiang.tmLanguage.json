{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YaoXiang",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#delimiters"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control",
          "match": "\\b(if|elif|else|match|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration",
          "match": "\\b(pub|use|spawn|ref|mut|unsafe)\\b"
        },
        {
          "name": "keyword.other",
          "match": "\\bas\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function",
          "match": "\\b(Type|true|false|void)\\b"
        },
        {
          "name": "support.function",
          "match": "\\b(Maybe\\.|Result\\.|Some\\(|Ok\\(|Err\\()"
        }
      ]
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted",
      "patterns": [
        {
          "name": "constant.character.escape",
          "match": "\\\\(\"|\\\\|[nrt\\\\])"
        },
        {
          "name": "string.interpolated",
          "match": "\\$\\{[^}]+\\}"
        },
        {
          "name": "string.interpolated",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.octal",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.binary",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.float",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.decimal",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash",
          "match": "//.*$"
        },
        {
          "name": "comment.block",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator",
          "match": "=>|->"
        },
        {
          "name": "keyword.operator",
          "match": "(=|\\+|-|\\*|/|%|==|!=|<|>|>=|<=|&&|\\|\\||!|::)"
        }
      ]
    },
    "delimiters": {
      "patterns": [
        {
          "name": "punctuation",
          "match": "[:,;\\[\\]{}\\(\\)]"
        }
      ]
    }
  },
  "scopeName": "source.yaoxiang"
}
