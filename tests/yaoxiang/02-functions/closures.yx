// 02-functions/closures.yx
// 覆盖: 规范 §6.3 高阶函数
// 验证: map/filter/reduce 闭包调用
// 状态: ✅ 可运行

use std.{io, list}

main = {
    mut items = [1, 2, 3, 4, 5]

    // map
    mut doubled = list.map(items, x => x * 2)
    io.println(doubled)

    // filter
    mut evens = list.filter(items, x => x % 2 == 0)
    io.println(evens)

    // reduce
    total = list.reduce(items, (acc, x) => acc + x, 0)
    io.println(total)

    // 链式操作 (filter + map)
    mut result = list.map(
        list.filter(items, x => x > 2),
        x => x * 10
    )
    io.println(result)

    io.println("ALL TESTS PASSED")
}
