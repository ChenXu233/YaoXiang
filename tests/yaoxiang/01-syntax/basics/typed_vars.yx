// 01-syntax/basics/typed_vars.yx
// 覆盖: 规范 §5.2 变量声明, §6.2 类型推导
// 验证: 带类型标注的变量声明 x: Int = 42
// 状态: ✅ 可运行

use std.io

// 模块级别类型标注
x: Int = 42
name: String = "YaoXiang"
flag: Bool = true
pi: Float = 3.14

main = {
    io.println(x)
    io.println(name)
    io.println(flag)
    io.println(pi)

    // 函数体内类型标注
    a: Int = 100
    io.println(a)

    // 可变类型标注
    mut counter: Int = 0
    counter = counter + 1
    io.println(counter)

    io.println("ALL TESTS PASSED")
}
