// 借用冲突检测: 活跃的不可变借用与 &mut self 方法调用冲突
// 预期: 编译错误 (E2017)
//
// Bug 3 修复验证: 方法调用应产生 Borrow 指令，
// BorrowChecker 应检测到显式 &p + p.shift(&mut self) 的冲突

use std.io

Point: Type = { x: Float, y: Float }

Point.read: (self: &Point) -> Void = {
    io.println(self.x)
}

Point.shift: (self: &mut Point, dx: Float) -> Void = {
    self.x = self.x + dx
}

main = {
    p = Point(1.0, 2.0)

    // 显式创建不可变借用 — 令牌保持活跃
    r = &p

    // 通过 &mut self 方法创建可变借用 — 与活跃的 r 冲突！
    p.shift(5.0)

    io.println("ALL TESTS PASSED")
}
