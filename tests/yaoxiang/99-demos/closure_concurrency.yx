// 99-demos/closure_concurrency.yx
// 验证: spawn + 数据共享混合模式
// 论文价值: spawn 内直接访问外层变量，无需 Send/Sync

use std.io

main = {
    data = 100

    result = spawn {
        // spawn 内直接访问外层 data
        double = data * 2
        triple = data * 3
        return (double, triple)
    }

    io.println(result)
    io.println("ALL TESTS PASSED")
}
