// 99-demos/closure_concurrency.yx
// 验证: 闭包 + 并发混合模式
// 论文价值: spawn + 闭包捕获，无需 Send/Sync

use std.io

main = {
    data = 100

    result = spawn {
        // 闭包捕获 data
        double = data * 2
        triple = data * 3
        return (double, triple)
    }

    io.println(result)
    io.println("ALL TESTS PASSED")
}
