// 08-ownership/freeze_basic.yx
// 验证: freeze(&mut T) → &T，流敏感分析正确
// 状态: 待测试

use std.io

Point: Type = { x: Float, y: Float }

modify_and_read: (p: &mut Point) -> Void = {
    p.x = 10.0
    view: &Point = freeze(p)
    io.println(view.x)
    p.y = 20.0
    io.println(p.y)
}

main = {
    p = Point(1.0, 2.0)
    modify_and_read(p)
    io.println("FREEZE TEST PASSED")
}
