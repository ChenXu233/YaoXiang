// 02-type-system/closures.yx
// 验证: 闭包和高阶函数
// 状态: 待测试

use std.{io, list}

main = {
    items = [1, 2, 3, 4, 5]

    // map: 每个元素乘以 2
    doubled = list.map(items, x => x * 2)
    io.println(doubled)

    // filter: 筛选偶数
    items2 = [1, 2, 3, 4, 5]
    evens = list.filter(items2, x => x % 2 == 0)
    io.println(evens)

    // reduce: 求和
    items3 = [1, 2, 3, 4, 5]
    total = list.reduce(items3, (acc, x) => acc + x, 0)
    io.println(total)

    // 链式操作
    items4 = [1, 2, 3, 4, 5]
    result = list.map(
        list.filter(items4, x => x > 2),
        x => x * 10
    )
    io.println(result)

    io.println("ALL TESTS PASSED")
}
