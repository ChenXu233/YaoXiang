// 01-basics/operators.yx
// 覆盖: 规范 §4.2 运算符优先级
// 验证: 算术、比较运算符
// 状态: ✅ 可运行

use std.io

main = {
    // 算术运算
    a = 10 + 20
    io.println(a)

    b = 100 - 30
    io.println(b)

    c = 6 * 7
    io.println(c)

    d = 42 / 2
    io.println(d)

    e = 10 % 3
    io.println(e)

    // 比较运算
    gt = 5 > 3
    io.println(gt)

    lt = 3 < 5
    io.println(lt)

    eq = 42 == 42
    io.println(eq)

    ne = 42 != 0
    io.println(ne)

    // 复合表达式
    mut result = (10 + 20) * 2 - 5
    io.println(result)

    io.println("ALL TESTS PASSED")
}
