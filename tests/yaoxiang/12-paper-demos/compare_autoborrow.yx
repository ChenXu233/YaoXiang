// 12-paper-demos/compare_autoborrow.yx
// 论文对比 2：自由函数自动借用 — 无需手动 &
// Rust 等效: distance(&p1, &p2) 需要显式 & 操作
// YaoXiang: 编译器自动插入借用

use std.io

Point: Type = { x: Float, y: Float }

// 自由函数，参数签名声明需要的权限
distance: (a: &Point, b: &Point) -> Float = {
    dx = a.x - b.x
    dy = a.y - b.y
    return dx * dx + dy * dy
}

main = {
    p1 = Point(0.0, 0.0)
    p2 = Point(3.0, 4.0)

    // 自动借用：p1, p2 是 Point 值，编译器自动创建 &Point 令牌
    // Rust 等效: distance(&p1, &p2) — 需要手动 &
    d = distance(p1, p2)
    io.println(d)

    io.println("ALL TESTS PASSED")
}
