// 12-paper-demos/linked_list.yx
// 验证: 自由函数自动借用 — 多个 &T 同时活跃
// 论文价值: Rust 需要生命周期，YaoXiang 编译器自动处理

use std.io

Node: Type = { value: Int }

// 自由函数：两个 &Node 参数 — 编译器自动创建令牌
compare: (a: &Node, b: &Node) -> Bool = {
    a.value > b.value
}

main = {
    a = Node(10)
    b = Node(20)
    c = Node(30)

    // 自动借用：a, b, c 是 Node，函数需要 &Node
    io.println(compare(b, a))
    io.println(compare(c, a))

    io.println("ALL TESTS PASSED")
}
