// 12-paper-demos/linked_list.yx
// 验证: 多个 &T 令牌共存 — Dup 类型属性
// 论文价值: Rust 需要生命周期 'a，YaoXiang 不需要

use std.io

Node: Type = { value: Int }

Node.is_greater: (self: &Node, other: &Node) -> Bool = {
    self.value > other.value
}

main = {
    a = Node(10)
    b = Node(20)
    c = Node(30)

    // 三个 &Node 令牌同时活跃 — Dup 类型属性允许
    io.println(b.is_greater(a))
    io.println(c.is_greater(a))

    io.println("ALL TESTS PASSED")
}
