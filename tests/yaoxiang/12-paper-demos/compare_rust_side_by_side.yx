// 12-paper-demos/compare_rust_side_by_side.yx
// 论文对比：同一个函数，Rust 需要 'a，YaoXiang 不需要
// 状态: 待测试

use std.io

Point: Type = { x: Float, y: Float }

// 视图类型：持有对 Point 的只读令牌
// Rust 等效: struct PointView<'a> { inner: &'a Point }
// YaoXiang: 无 'a，令牌自动管理
PointView: Type = {
    inner: &Point
}

// 通过视图读取
// Rust 等效: fn get_x<'a>(view: &PointView<'a>) -> f64 { view.inner.x }
// YaoXiang: 无 'a，参数类型自动推导
get_x: (view: &PointView) -> Float = {
    return view.inner.x
}

main = {
    p = Point(3.0, 4.0)
    v = PointView(p)
    x = get_x(v)
    io.println(x)
    io.println("ALL TESTS PASSED")
}
