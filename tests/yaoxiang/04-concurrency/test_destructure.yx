// 04-concurrency/test_destructure.yx
// 覆盖: 元组解构赋值语法
// 验证: `a, b = (1, 2)` 和 `(a, b) = (1, 2)` 两种形式
// 状态: ✅ 可运行

use std.io
main = {
    // Non-paren form: a, b = (1, 2)
    a, b = (1, 2)
    io.println(a)
    io.println(b);

    // Parenthesized form: (c, d) = (3, 4)
    (c, d) = (3, 4)
    io.println(c)
    io.println(d);

    // Three-element destructuring
    x, y, z = (10, 20, 30)
    io.println(x)
    io.println(y)
    io.println(z);

    io.println("ALL TESTS PASSED")
}
