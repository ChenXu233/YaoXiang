// 06-compile-errors/assert_compile_error.yx
// 覆盖: RFC-011 §4.3 编译期验证 — Assert(N > 0) 约束违反应编译报错
// 验证: const 泛型参数 N=0 时 Assert(0 > 0) 求值为 false，编译失败
// 状态: ❌ 应编译失败

use std.io

BadArray: (T: Type, N: Int) -> Type = {
    _assert_n: Assert(N > 0),
    data: Array(T, N),
}

main = {
    bad = BadArray(Int, 0)
    io.println("SHOULD NOT REACH HERE")
}